{
  "version": 2,
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "*.json"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/news/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!api/|news/).*)",
      "destination": "/index.html"
    }
  ]
}
