{
  "version": 2,
  "functions": {
    "api/*.ts": {
      "includeFiles": "*.json"
    },
    "api/index.ts": {
      "includeFiles": "*.json"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
